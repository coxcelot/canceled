if __name__ == "__main__":
print(f"Device: {DEVICE}")
agent = Agent()

def get_batches(batch_size=4, seq_len=64):
pattern = b"the quick brown fox jumps over the lazy dog "
while True:
batch = []
for _ in range(batch_size):
repeat = (seq_len // len(pattern)) + 2
data = (pattern * repeat)[:seq_len]
batch.append(data)
yield batch

steps = 500
data_gen = get_batches(batch_size=4)

print("Starting training...")
for step in range(steps):
batch = next(data_gen)
metrics = agent.train(batch)
if step % 50 == 0:
print(f"Step {step:03d} | loss: {metrics['loss']:.4f} | gates: {[f'{g:.3f}' for g in metrics['gates']]} | entropy: {[f'{e:.3f}' for e in metrics['attn_entropy']]}")

agent.save("agent.pt")
print("Checkpoint saved to agent.pt")

# Inference demo
prompt = b"the quick"
out = agent.generate(prompt, max_new_tokens=50)
print(f"\\nPrompt: {prompt}")
print(f"Generated: {out}")
