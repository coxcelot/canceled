  const generationCount = useRef(0);

  const addLog = useCallback((msg) => {
    const t = new Date().toLocaleTimeString('en-US',{hour12:false});
    setLogs(prev => [`[${t}] ${msg}`, ...prev].slice(0,100));
  }, []);

  useEffect(() => {
    hdcWorker.current = new Worker(workerUrl);
    hdcWorker.current.onmessage = (e) => {
      const { id, result } = e.data;
      if(pendingPromises.current[id]) {
        pendingPromises.current[id].resolve(result);
        delete pendingPromises.current[id];
      }
    };
    return () => hdcWorker.current.terminate();
  }, []);

  const askWorker = useCallback((type, payload, extra={}) => {
    return new Promise((resolve, reject) => {
      const id = Math.random().toString(36).substr(2,9);
      pendingPromises.current[id] = { resolve, reject };
      hdcWorker.current.postMessage({ type, payload, id, ...extra });
