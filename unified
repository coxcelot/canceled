  return sum;
}

function vectorizeRoles(str) {
  const r = extractRoles(str);
  const res = {};
  const tmp = new Float32Array(D);
  if(r.agent) { circConv(ROLE_AGENT, getTokenVector(r.agent), tmp); res.agent = packFloat(new Float32Array(tmp)); }
  if(r.pred) { circConv(ROLE_PRED, getTokenVector(r.pred), tmp); res.pred = packFloat(new Float32Array(tmp)); }
  if(r.patient) { circConv(ROLE_PATIENT, getTokenVector(r.patient), tmp); res.patient = packFloat(new Float32Array(tmp)); }
  if(r.context.length) {
    tmp.fill(0);
    const ctxTmp = new Float32Array(D);
    for(const c of r.context) { circConv(ROLE_CONTEXT, getTokenVector(c), ctxTmp); for(let j = 0; j < D; j++) tmp[j] += ctxTmp[j]; }
    let norm = 0; for(let j = 0; j < D; j++) norm += tmp[j] * tmp[j];
    norm = Math.sqrt(norm) || 1; for(let j = 0; j < D; j++) tmp[j] /= norm;
    res.context = packFloat(new Float32Array(tmp));
  }
  return res;
}

// --- SIMILARITY (cosine on real vectors) ---
function cosineReal(a, b) {
  let dot = 0, n1 = 0, n2 = 0;
  for(let i = 0; i < D; i++) { dot += a[i] * b[i]; n1 += a[i] * a[i]; n2 += b[i] * b[i]; }
  return dot / (Math.sqrt(n1 * n2) || 1);
}

function dotReal(a, b) {
  let d = 0;
  for(let i = 0; i < D; i++) d += a[i] * b[i];
  return d;
}

// --- CLEANUP MEMORY ---
function cleanup(unbound, cands) {
  let best = null, bestSc = -Infinity;
  for(const t of cands) {
    const tv = getTokenVector(t);
    const s = dotReal(unbound, tv);
    if(s > bestSc) { bestSc = s; best = t; }
  }
  return { token: best, sim: bestSc };
}

// --- EIGENMEMORY (OJA) ---
const EIGEN_K = 32;

function initEigen() {
  if(eigenMemories) return;
  eigenMemories = [];
  const r = mulberry32(777);
  for(let k = 0; k < EIGEN_K; k++) {
    const v = new Float32Array(D);
    for(let i = 0; i < D; i++) v[i] = r() > 0.5 ? 1 : -1;
    let n = 0; for(let i = 0; i < D; i++) n += v[i] * v[i];
    n = Math.sqrt(n); for(let i = 0; i < D; i++) v[i] /= n;
    eigenMemories.push(v);
  }
}

function ojaUpdate(vec, lr=0.002) {
  initEigen();
  for(let k = 0; k < EIGEN_K; k++) {
    const e = eigenMemories[k];
    let proj = 0; for(let i = 0; i < D; i++) proj += vec[i] * e[i];
    for(let i = 0; i < D; i++) e[i] += lr * (vec[i] * proj - e[i] * proj * proj);
    let n = 0; for(let i = 0; i < D; i++) n += e[i] * e[i];
    n = Math.sqrt(n); if(n > 0) for(let i = 0; i < D; i++) e[i] /= n;
  }
}

function computeEcho(vec) {
  initEigen();
  const out = new Float32Array(D);
  for(let k = 0; k < EIGEN_K; k++) {
    const e = eigenMemories[k];
    let p = 0; for(let i = 0; i < D; i++) p += vec[i] * e[i];
    for(let i = 0; i < D; i++) out[i] += p * e[i];
  }
  let n = 0; for(let i = 0; i < D; i++) n += out[i] * out[i];
  n = Math.sqrt(n) || 1; for(let i = 0; i < D; i++) out[i] /= n;
  return out;
}

// --- LSH ---
function initLSH() {
  if(lshHP) return;
  lshHP = [];
  const r = mulberry32(999);
  for(let h = 0; h < LSH_H; h++) {
    const hp = new Float32Array(D);
    for(let i = 0; i < D; i++) hp[i] = r() > 0.5 ? 1 : -1;
    lshHP.push(hp);
  }
}

function lshHashReal(vec) {
  let h = 0;
  for(let b = 0; b < LSH_H; b++) {
    let d = 0; for(let i = 0; i < D; i++) d += vec[i] * lshHP[b][i];
    if(d > 0) h |= (1 << b);
  }
  return h;
}

function buildLSH() {
  initLSH();
  lshIndex = new Map();
  for(const [id, n] of nodeMap) {
    const h = lshHashReal(n.vector);
    if(!lshIndex.has(h)) lshIndex.set(h, new Set());
    lshIndex.get(h).add(id);
  }
}

function lshCandidateIds(vec, excludeId) {
  if(!lshIndex) buildLSH();
  const h = lshHashReal(vec);
  const cands = new Set();
  const own = lshIndex.get(h);
  if(own) for(const id of own) if(id !== excludeId) cands.add(id);
  for(let b = 0; b < LSH_H; b++) {
    const bucket = lshIndex.get(h ^ (1 << b));
    if(bucket) for(const id of bucket) if(id !== excludeId) cands.add(id);
  }
  for(let b1 = 0; b1 < LSH_H; b1++) {
    for(let b2 = b1 + 1; b2 < LSH_H; b2++) {
      const bucket = lshIndex.get(h ^ (1 << b1) ^ (1 << b2));
      if(bucket) for(const id of bucket) if(id !== excludeId) cands.add(id);
    }
  }
  return cands;
}

// --- INCREMENTAL k-NN GRAPH ---
function syncPool(pool) {
  const currIds = new Set(pool.map(n => n.id));
  // Remove dead
  for(const id of lastPoolIds) {
    if(!currIds.has(id)) {
      nodeMap.delete(id);
      knnGraph.delete(id);
      for(const [_, meta] of knnGraph) meta.neighbors = meta.neighbors.filter(n => n.id !== id);
    }
  }
  // Add new
  const newIds = [];
  for(const n of pool) {
    if(!nodeMap.has(n.id)) {
      const vec = unpackFloat(n.vector);
      const roles = {};
      if(n.roleAgent) roles.agent = unpackFloat(n.roleAgent);
      if(n.rolePred) roles.pred = unpackFloat(n.rolePred);
      if(n.rolePatient) roles.patient = unpackFloat(n.rolePatient);
      if(n.roleContext) roles.context = unpackFloat(n.roleContext);
      nodeMap.set(n.id, { vector: vec, roles, text: n.text, score: n.score || 1, timestamp: n.timestamp });
      knnGraph.set(n.id, { neighbors: [], dirty: true });
      newIds.push(n.id);
    }
  }
  lastPoolIds = currIds;
  if(newIds.length > 0) buildLSH();

  // Update dirty nodes and bidirectional edges
  for(const nid of newIds) {
    const vec = nodeMap.get(nid).vector;
    const candSet = lshCandidateIds(vec, nid);
    const neighbors = [];
    for(const cid of candSet) {
      const sim = cosineReal(vec, nodeMap.get(cid).vector);
      if(sim > 0.01) neighbors.push({ id: cid, sim });
    }
    neighbors.sort((a, b) => b.sim - a.sim);
    const top = neighbors.slice(0, KNN_K);
    knnGraph.get(nid).neighbors = top;
    knnGraph.get(nid).dirty = false;

    for(const nb of top) {
      const other = knnGraph.get(nb.id);
      const ex = other.neighbors.find(x => x.id === nid);
      if(ex) ex.sim = nb.sim;
      else {
        other.neighbors.push({ id: nid, sim: nb.sim });
        other.neighbors.sort((a, b) => b.sim - a.sim);
        if(other.neighbors.length > KNN_K) other.neighbors.pop();
      }
    }
  }
}

// --- MESSAGE HANDLER ---
self.onmessage = function(e) {
  const { type, payload, id, pool, config } = e.data;

  if(type === 'VECTORIZE') {
    const vec = vectorizeString(payload);
    const roles = vectorizeRoles(payload);
    self.postMessage({ id, result: { vector: packFloat(vec), agent: roles.agent, pred: roles.pred, patient: roles.patient, context: roles.context } });
  }
  else if(type === 'GENERATE') {
    syncPool(pool);
    const qVec = vectorizeString(payload);
    const qRoles = vectorizeRoles(payload);
    const qEcho = computeEcho(qVec);
    if(nodeMap.size === 0) { self.postMessage({ id, result: { text: "", usedIds: [] } }); return; }

    const gw = config.graphWeight != null ? config.graphWeight : 0.3;
    const ew = config.echoWeight != null ? config.echoWeight : 0.15;
    const temp = Math.max(0.01, config.samplingTemp != null ? config.samplingTemp : 0.6);

    // Candidate generation: LSH + random sample to prevent bucket collapse
    const lshSet = lshCandidateIds(qVec, null);
    const allIds = Array.from(nodeMap.keys());
    const randSet = new Set();
    while(randSet.size < Math.min(20, allIds.length)) randSet.add(allIds[Math.floor(Math.random() * allIds.length)]);
    const candIds = new Set([...lshSet, ...randSet]);
    const cands = Array.from(candIds).map(cid => ({ id: cid, ...nodeMap.get(cid) }));

    const scored = cands.map(n => {
      const simContent = cosineReal(qVec, n.vector);
      let structSim = 0, structCnt = 0;
      if(n.roles?.agent && qRoles.agent) { structSim += cosineReal(n.roles.agent, qRoles.agent); structCnt++; }
      if(n.roles?.pred && qRoles.pred) { structSim += cosineReal(n.roles.pred, qRoles.pred); structCnt++; }
      if(n.roles?.patient && qRoles.patient) { structSim += cosineReal(n.roles.patient, qRoles.patient); structCnt++; }
      if(n.roles?.context && qRoles.context) { structSim += cosineReal(n.roles.context, qRoles.context); structCnt++; }
      const ns = structCnt > 0 ? structSim / structCnt : 0;
      const echoSim = cosineReal(qEcho, n.vector);
      return { ...n, sim: (1 - gw - ew) * simContent + gw * ns + ew * echoSim };
    });

    const sims = scored.map(n => n.sim);
    const maxSim = Math.max(...sims);
    let sumExp = 0;
    const exps = sims.map(s => { const e = Math.exp((s - maxSim) / temp); sumExp += e; return e; });
    const probs = exps.map(e => e / sumExp);

    const sampleSize = Math.min(config.topK, scored.length);
    const selIdx = [];
    while(selIdx.length < sampleSize) {
      let r = Math.random(), cum = 0, ch = -1;
      for(let i = 0; i < scored.length; i++) {
        if(selIdx.includes(i)) continue;
        cum += probs[i];
        if(r <= cum) { ch = i; break; }
      }
      if(ch !== -1) selIdx.push(ch); else break;
    }
    let topPool = selIdx.map(i => scored[i]);

    // MMR diversification
    const lambda = config.diversityLambda != null ? config.diversityLambda : 0.5;
    const selected = [];
    for(let i = 0; i < Math.min(topPool.length, 3); i++) {
      let bestIdx = -1, bestScore = -Infinity;
      for(let j = 0; j < topPool.length; j++) {
        if(selected.includes(j)) continue;
        let s1 = topPool[j].sim, maxS2 = 0;
        for(const sel of selected) {
          const s = cosineReal(topPool[j].vector, topPool[sel].vector);
          if(s > maxS2) maxS2 = s;
        }
        const mmr = lambda * s1 - (1 - lambda) * maxS2;
        if(mmr > bestScore) { bestScore = mmr; bestIdx = j; }
      }
      if(bestIdx !== -1) selected.push(bestIdx);
    }

    // Coherence-guarded assembly
    const primary = topPool[selected];
    let text = primary.text;
    let usedIds = [primary.id];

    if(selected.length > 1) {
      const pToks = new Set(tokenize(primary.text));
      const related = [];
      for(let k = 1; k < selected.length; k++) {
        const sec = topPool[selected[k]];
        if(cosineReal(primary.vector, sec.vector) < 0.35) continue;
        const secToks = tokenize(sec.text);
        const overlap = secToks.filter(t => pToks.has(t) && !SW.has(t) && t.length > 2).length > 0;
        if(!overlap) continue;
        related.push(sec.text);
        usedIds.push(sec.id);
      }
      if(related.length > 0) text = [primary.text, ...related].join(" | ");
    }

    // Strong validation
    const toks = tokenize(text);
    const content = toks.filter(t => !SW.has(t) && t.length > 2);
    const counts = {};
    for(const t of toks) counts[t] = (counts[t] || 0) + 1;
    const maxFreq = Math.max(0, ...Object.values(counts));
    const valid = toks.length >= 4 && content.length >= 3 && (maxFreq / toks.length) <= 0.3;
    if(!valid) { text = primary.text; usedIds = [primary.id]; }

    self.postMessage({ id, result: { text, usedIds } });
  }
  else if(type === 'EVALUATE') {
    syncPool(pool);
    const cVec = unpackFloat(payload);
    let maxSim = -Infinity;
    for(const [_, n] of nodeMap) {
      const s = cosineReal(cVec, n.vector);
      if(s > maxSim) maxSim = s;
    }
    self.postMessage({ id, result: maxSim });
  }
  else if(type === 'CROSSOVER') {
    const { p1Text, p2Text, rescue } = e.data;
    const r1 = extractRoles(p1Text), r2 = extractRoles(p2Text);
    const allToks = [...new Set([...tokenize(p1Text), ...tokenize(p2Text)])].filter(t => t.length > 0);
    const parts = [];
    const outBuf = new Float32Array(D);

    for(const role of ['agent','pred','patient']) {
      const rvec = role === 'agent' ? ROLE_AGENT : role === 'pred' ? ROLE_PRED : ROLE_PATIENT;
      if(r1[role] && r2[role]) {
        const v1 = getTokenVector(r1[role]);
        const v2 = getTokenVector(r2[role]);
        for(let j = 0; j < D; j++) outBuf[j] = v1[j] + v2[j];
        circCorr(outBuf, rvec, outBuf);
        const c = cleanup(outBuf, allToks);
        if(c.token) parts.push(c.token);
      } else if(r1[role] || r2[role]) {
        const src = getTokenVector(r1[role] || r2[role]);
        circCorr(src, rvec, outBuf);
        const c = cleanup(outBuf, allToks);
        if(c.token) parts.push(c.token);
      }
    }

    if(r1.context.length || r2.context.length) {
      outBuf.fill(0);
      const tmp = new Float32Array(D);
      for(const c of r1.context) { circConv(ROLE_CONTEXT, getTokenVector(c), tmp); for(let j=0;j<D;j++) outBuf[j]+=tmp[j]; }
      for(const c of r2.context) { circConv(ROLE_CONTEXT, getTokenVector(c), tmp); for(let j=0;j<D;j++) outBuf[j]+=tmp[j]; }
      circCorr(outBuf, ROLE_CONTEXT, outBuf);
      const remain = allToks.filter(t => !parts.includes(t));
      const scored = remain.map(t => ({ t, s: dotReal(outBuf, getTokenVector(t)) }));
      scored.sort((a,b) => b.s - a.s);
      for(const c of scored.slice(0, rescue ? 5 : 3)) parts.push(c.t);
    }

    const text = parts.join(" ");
    self.postMessage({ id, result: { text, confidence: parts.length > 2 ? 1 : 0 } });
  }
  else if(type === 'FITNESS') {
    const { candidateVec, candidateText } = e.data;
    syncPool(pool);
    const cVec = unpackFloat(candidateVec);

    // Attractor penalty: avg sim to top-5 LSH neighbors of candidate
    const candHash = lshHashReal(cVec);
    const bucket = lshIndex ? lshIndex.get(candHash) : null;
    let penalty = 0, pCnt = 0;
    if(bucket) {
      const arr = Array.from(bucket).slice(0, 5);
      for(const nid of arr) {
        const n = nodeMap.get(nid);
        if(n) { penalty += cosineReal(cVec, n.vector); pCnt++; }
      }
    }
    penalty = pCnt > 0 ? (penalty / pCnt) * 0.4 : 0;

    const probes = [candidateText];
    const toks = tokenize(candidateText);
    if(toks.length > 2) {
      probes.push(toks.slice(0, Math.ceil(toks.length/2)).join(" "));
      probes.push([...toks].sort(()=>Math.random()-0.5).join(" "));
    }
    let totalRank = 0;
    for(const probe of probes) {
      const qv = vectorizeString(probe);
      const childSim = cosineReal(qv, cVec);
      // Rank against random sample of 40 nodes (sub-quadratic)
      const sample = [];
      const ids = Array.from(nodeMap.keys());
      while(sample.length < Math.min(40, ids.length)) {
        const rid = ids[Math.floor(Math.random()*ids.length)];
        if(!sample.includes(rid)) sample.push(rid);
      }
      let rank = 0;
      for(const sid of sample) {
        if(cosineReal(qv, nodeMap.get(sid).vector) > childSim) rank++;
      }
      totalRank += rank;
    }
    const avgRank = totalRank / probes.length;
    const rawFitness = Math.max(0, 1 - avgRank / (Math.min(40, nodeMap.size) || 1));
    const fitness = Math.max(0, rawFitness - penalty);
    self.postMessage({ id, result: fitness });
  }
  else if(type === 'ENTROPY') {
    syncPool(pool);
    let total = 0, cnt = 0;
    for(const [_, meta] of knnGraph) {
      if(meta.neighbors.length > 0) { total += meta.neighbors.sim; cnt++; }
    }
    const avgMax = cnt > 0 ? total / cnt : 0;
    self.postMessage({ id, result: avgMax });
  }
  else if(type === 'DISTANT_PARENT') {
    const { nodeId } = e.data;
    syncPool(pool);
    const meta = knnGraph.get(nodeId);
    let chosen = null;
    if(meta && meta.neighbors.length > 0) {
      // Least similar neighbor = distant parent
      chosen = meta.neighbors[meta.neighbors.length - 1].id;
    } else {
      const ids = Array.from(nodeMap.keys());
      chosen = ids[Math.floor(Math.random() * ids.length)];
    }
    self.postMessage({ id, result: chosen });
  }
  else if(type === 'EIGEN_UPDATE') {
    ojaUpdate(unpackFloat(e.data.vector));
    self.postMessage({ id, result: true });
  }
  else if(type === 'EIGEN_SERIALIZE') {
    initEigen();
    self.postMessage({ id, result: eigenMemories.map(e => Array.from(e)) });
  }
  else if(type === 'EIGEN_LOAD') {
    const v = e.data.vectors;
    eigenMemories = v.map(arr => { const f = new Float32Array(D); f.set(arr); return f; });
    self.postMessage({ id, result: true });
  }
  else if(type === 'DECAY') {
    const rate = e.data.rate || 0.98;
    const updated = pool.map(n => ({ id: n.id, score: (n.score || 1) * rate }));
    self.postMessage({ id, result: updated });
  }
  else if(type === 'PRUNE') {
    const maxNodes = e.data.maxNodes || 120;
    syncPool(pool);
    if(nodeMap.size <= maxNodes) {
      self.postMessage({ id, result: { toRemove: [], avgRedundancy: 0 } });
      return;
    }
    // Rank-normalize scores
    const entries = Array.from(nodeMap.entries()).map(([id, n]) => ({ id, ...n }));
    entries.sort((a, b) => (b.score || 1) - (a.score || 1));
    entries.forEach((n, i) => { n.rankNormScore = (n.score || 1) / Math.log2(i + 2); });

    const red = new Float32Array(entries.length);
    for(let i = 0; i < entries.length; i++) {
      const meta = knnGraph.get(entries[i].id);
      red[i] = meta && meta.neighbors.length > 0 ? meta.neighbors.sim : 0;
    }
    const indexed = entries.map((n, i) => ({ id: n.id, utility: (n.rankNormScore || 1) / (1 + red[i]) }));
    indexed.sort((a, b) => a.utility - b.utility);
    const toRemove = indexed.slice(0, entries.length - maxNodes).map(x => x.id);
    for(const rid of toRemove) {
      nodeMap.delete(rid);
      knnGraph.delete(rid);
      for(const [_, meta] of knnGraph) meta.neighbors = meta.neighbors.filter(x => x.id !== rid);
    }
    const avgRed = red.reduce((a, b) => a + b, 0) / red.length;
    self.postMessage({ id, result: { toRemove, avgRedundancy: avgRed } });
  }
  else if(type === 'CLEAR_CACHE') {
    nodeMap.clear();
    knnGraph.clear();
    lastPoolIds.clear();
    lshHP = null; lshIndex = null;
    eigenMemories = null;
    self.postMessage({ id, result: true });
  }
};
`;
const workerBlob = new Blob([hdcWorkerCode], { type: 'application/javascript' });
