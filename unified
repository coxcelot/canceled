  useEffect(() => {
    if(isEvolutionActive) evolutionTimer.current = setInterval(evolve, config.evolutionRate);
    else if(evolutionTimer.current) clearInterval(evolutionTimer.current);
    return () => clearInterval(evolutionTimer.current);
  }, [isEvolutionActive, config.evolutionRate]);

  const saveNode = async (node) => {
    await dbPut('nodes', node);
  };

  const deleteNode = async (id) => {
    await dbDelete('nodes', id);
  };

  const evolve = async () => {
    if(memoryBank.current.length < 5) return;
    generationCount.current++;
    setTelemetry(prev => ({ ...prev, evolutionGen: generationCount.current }));

    // 1. Decay
    const decayed = await askWorker('DECAY', null, { pool: memoryBank.current, rate: rescueMode.current ? 0.85 : config.decayRate });
    for(const d of decayed) {
      const n = nodeMapRef.current.get(d.id);
      if(n) { n.score = d.score; await saveNode(n); }
    }

    // 2. Entropy check
    const entropy = await askWorker('ENTROPY', null, { pool: memoryBank.current });
    entropyHistory.current.push(entropy);
    if(entropyHistory.current.length > 5) entropyHistory.current.shift();
    const avgEnt = entropyHistory.current.slice(-3).reduce((a,b)=>a+b,0)/3;

    if(avgEnt > 0.65 && !rescueMode.current) {
      rescueMode.current = true;
      addLog(`[RESCUE] Entropy ${avgEnt.toFixed(3)}. Activating distant-parent mode.`);
      setTelemetry(prev => ({ ...prev, rescue: true }));
    } else if(avgEnt < 0.55 && rescueMode.current) {
      rescueMode.current = false;
      addLog(`[RESCUE] Entropy normalized ${avgEnt.toFixed(3)}.`);
      setTelemetry(prev => ({ ...prev, rescue: false }));
    }
    setTelemetry(prev => ({ ...prev, entropy: entropy.toFixed(3) }));

    // 3. Parent selection (distant in rescue mode)
    const pool = memoryBank.current;
    const idxA = Math.floor(Math.random() * pool.length);
    let idxB;
    if(rescueMode.current && pool.length > 20) {
      const distantId = await askWorker('DISTANT_PARENT', null, { nodeId: pool[idxA].id, pool });
      idxB = pool.findIndex(n => n.id === distantId);
      if(idxB === -1 || idxB === idxA) {
        idxB = Math.floor(Math.random() * pool.length);
        while(idxB === idxA) idxB = Math.floor(Math.random() * pool.length);
      }
    } else {
      idxB = Math.floor(Math.random() * pool.length);
      while(idxB === idxA) idxB = Math.floor(Math.random() * pool.length);
    }

    // 4. Crossover
    const vecChild = await askWorker('CROSSOVER', null, { p1Text: pool[idxA].text, p2Text: pool[idxB].text, rescue: rescueMode.current });
    let childText = vecChild.text;
    if(!childText || childText.length < 5 || vecChild.confidence < 0.3) {
      const tA = pool[idxA].text.split(/\\s+/);
      const tB = pool[idxB].text.split(/\\s+/);
      const pA = Math.floor(Math.random() * (tA.length-1)) + 1;
      const pB = Math.floor(Math.random() * (tB.length-1)) + 1;
      childText = [...tA.slice(0,pA), ...tB.slice(pB)].join(" ");
    }

    // 5. Vectorize (real-valued)
    const packed = await askWorker('VECTORIZE', childText);

    // 6. Fitness & Novelty
    const rawFitness = await askWorker('FITNESS', null, { candidateVec: packed.vector, candidateText: childText, pool: memoryBank.current });
    const maxSim = await askWorker('EVALUATE', null, { candidate: packed.vector, pool: memoryBank.current });

    // 7. Probabilistic acceptance gate (sigmoid)
    const a = 6.0, b = 8.0, c = 2.0;
    const entPenalty = Math.max(0, avgEnt - 0.5);
    const rescueBonus = rescueMode.current ? 2.0 : 0;
    const z = a * rawFitness - b * maxSim - c * entPenalty + rescueBonus;
    const prob = 1 / (1 + Math.exp(-z));
    const accepted = Math.random() < prob;

    if(accepted) {
      const id = 'node_' + Date.now() + '_' + Math.random().toString(36).substr(2,5);
      const newNode = {
        id, text: childText, vector: packed.vector,
        roleAgent: packed.agent, rolePred: packed.pred,
        rolePatient: packed.patient, roleContext: packed.context,
        timestamp: Date.now(), type: 'evolved',
        score: 1.0 + rawFitness,
        birthGen: generationCount.current
      };
      memoryBank.current.push(newNode);
      nodeMapRef.current.set(id, newNode);
      await saveNode(newNode);
      setTelemetry(prev => ({ ...prev, nodes: memoryBank.current.length }));

      await askWorker('EIGEN_UPDATE', null, { vector: packed.vector });
      if(generationCount.current % 5 === 0) {
        const eigenSer = await askWorker('EIGEN_SERIALIZE', null, {});
        await dbPut('meta', { key: 'eigen', vectors: eigenSer });
      }

      // 8. Lazy prune with k-NN graph
      const watermark = Math.floor(config.maxMemory * 1.25);
      if(memoryBank.current.length > watermark) {
        const pruneRes = await askWorker('PRUNE', null, { pool: memoryBank.current, maxNodes: config.maxMemory });
        const { toRemove, avgRedundancy } = pruneRes;
        if(toRemove.length > 0) {
          for(const rid of toRemove) {
            await deleteNode(rid);
            memoryBank.current = memoryBank.current.filter(n => n.id !== rid);
            nodeMapRef.current.delete(rid);
          }
          const newGate = Math.min(0.94, avgRedundancy + 0.08);
          setConfig(prev => ({ ...prev, noveltyThreshold: newGate }));
          addLog(`[SYSTEM] Pruned ${toRemove.length}. Red: ${avgRedundancy.toFixed(3)} | Gate: ${newGate.toFixed(3)} | Fit: ${rawFitness.toFixed(3)} | Prob: ${prob.toFixed(3)} | Ent: ${avgEnt.toFixed(3)}`);
          setTelemetry(prev => ({ ...prev, nodes: memoryBank.current.length }));
        }
      }
    } else {
      addLog(`[EVOLVE] Rejected. Fit: ${rawFitness.toFixed(3)} | Nov: ${maxSim.toFixed(3)} | Prob: ${prob.toFixed(3)} | Ent: ${avgEnt.toFixed(3)}`);
    }

    await dbPut('meta', { key: 'config', value: { ...config, noveltyThreshold: config.noveltyThreshold } });
    await dbPut('meta', { key: 'generation', value: generationCount.current });
  };

  const triggerBootstrap = async () => {
    addLog("[SYSTEM] Sowing stable seeds...");
    const seeds = [
      "Entropy is the arrow time follows.",
      "Information decays into structure.",
      "Consciousness is a recursive boundary condition.",
      "Meaning emerges from constrained randomness.",
      "The universe computes its own existence.",
      "Memory is the gravity of thought.",
      "Every system contains the ghost of its observer.",
      "Chaos and order are conjugate variables.",
      "Reality is the stable fixed point of perception.",
      "Syntax is the fossil of intention."
    ];
    for(const shard of seeds) {
      const packed = await askWorker('VECTORIZE', shard);
      const id = 'seed_' + Date.now() + '_' + Math.random().toString(36).substr(2,5);
      const node = {
        id, text: shard, vector: packed.vector,
        roleAgent: packed.agent, rolePred: packed.pred,
        rolePatient: packed.patient, roleContext: packed.context,
        timestamp: Date.now(), type: 'seed', score: 1.0, birthGen: 0
      };
      memoryBank.current.push(node);
      nodeMapRef.current.set(id, node);
      await saveNode(node);
    }
    addLog("[SYSTEM] Seeds sown. Evolution active.");
    setIsEvolutionActive(true);
    setTelemetry(prev => ({ ...prev, nodes: memoryBank.current.length }));
  };

  const generateResponse = async (queryText) => {
    return await askWorker('GENERATE', queryText, { pool: memoryBank.current, config });
  };

  const exportModel = async () => {
    addLog("[SYSTEM] Exporting stable brain...");
    const nodes = await dbGetAll('nodes');
    const meta = await dbGetAll('meta');
    const eigenMeta = meta.find(m => m.key === 'eigen');
    const model = {
      manifest: { name: "Neural Anarchy Stable", architecture: "HDC+HRR+Eigenmemory+kNN", dimension: 2048, generated_at: new Date().toISOString(), node_count: nodes.length },
      runtime_engine: { logic: hdcWorkerCode.trim() },
      config,
      eigenmemory: eigenMeta ? eigenMeta.vectors : null,
      weights: nodes.map(n => ({ t: n.text, v: n.vector, ra: n.roleAgent, rp: n.rolePred, rt: n.rolePatient, rc: n.roleContext, s: n.score || 1 }))
    };
    const blob = new Blob([JSON.stringify(model, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `stable_brain_${Date.now()}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    addLog("[SYSTEM] Export complete.");
  };

  const importModel = async (file) => {
    const text = await file.text();
    const model = JSON.parse(text);
    if(!model.weights) { addLog("[ERROR] Invalid brain file."); return; }
    await wipeMemory(false);
    for(const w of model.weights) {
      const id = 'imp_' + Date.now() + '_' + Math.random().toString(36).substr(2,5);
      const node = { id, text: w.t, vector: w.v, roleAgent: w.ra, rolePred: w.rp, rolePatient: w.rt, roleContext: w.rc, score: w.s || 1, timestamp: Date.now(), type: 'imported', birthGen: 0 };
      memoryBank.current.push(node);
      nodeMapRef.current.set(id, node);
      await saveNode(node);
    }
    if(model.eigenmemory) {
      await askWorker('EIGEN_LOAD', null, { vectors: model.eigenmemory });
      await dbPut('meta', { key: 'eigen', vectors: model.eigenmemory });
    }
    setTelemetry(prev => ({ ...prev, nodes: memoryBank.current.length }));
    addLog(`[SYSTEM] Imported ${model.weights.length} nodes.`);
  };

  const wipeMemory = async (log=true) => {
    setIsEvolutionActive(false);
    await dbClear('nodes');
    await dbClear('meta');
    await askWorker('CLEAR_CACHE');
    memoryBank.current = [];
    nodeMapRef.current = new Map();
    entropyHistory.current = [];
    rescueMode.current = false;
    generationCount.current = 0;
    if(log) addLog("Field Purged.");
    setTelemetry({ nodes:0, evolutionGen:0, entropy:0, rescue:false });
  };

  const handleExecute = async () => {
    if(!prompt.trim() || isGenerating.current) return;
    const p = prompt; setPrompt("");
    setChat(prev => [...prev, {role:'user', text:p}]);
    isGenerating.current = true;
    const resObj = await generateResponse(p);
    let text = resObj.text || "Latency silent.";

    if(resObj.usedIds && resObj.usedIds.length > 0) {
      for(const uid of resObj.usedIds) {
        const n = nodeMapRef.current.get(uid);
        if(n) {
          n.score = (n.score || 1) + 0.25;
          await saveNode(n);
        }
      }
    }

    setChat(prev => [...prev, {role:'system', text}]);
    isGenerating.current = false;
  };

  return (
    <div className="h-screen flex flex-col relative text-slate-300">
      <header className="glass-panel p-4 flex justify-between items-center shadow-lg border-b border-cyan-500/10">
        <div className="flex items-center gap-4">
          <div className={`w-3 h-3 rounded-full ${isEvolutionActive ? 'bg-cyan-400 glow-pulse' : 'bg-slate-700'}`}></div>
          <h1 className="text-xl font-black tracking-tighter italic text-cyan-400">CANCELED_FRONTIER <span className="text-[10px] font-normal text-slate-500 ml-2">V8.0_STABLE</span></h1>
        </div>
        <div className="flex gap-2">
          <button onClick={triggerBootstrap} className="bg-white text-black px-4 py-2 rounded text-[10px] font-black uppercase tracking-widest hover:scale-105 transition-all">Bootstrap</button>
          <button onClick={exportModel} className="bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-2 rounded text-[10px] uppercase font-bold transition-all">Export</button>
          <label className="bg-slate-700 hover:bg-slate-600 text-white px-4 py-2 rounded text-[10px] uppercase font-bold transition-all cursor-pointer">
            Import
            <input type="file" accept=".json" className="hidden" onChange={e => { if(e.target.files) importModel(e.target.files); e.target.value=''; }} />
          </label>
          <button onClick={() => setIsModalOpen(true)} className="bg-slate-800 px-3 py-2 rounded text-[10px] uppercase font-bold">Field View</button>
        </div>
      </header>

      <main className="flex-1 grid grid-cols-1 lg:grid-cols-4 gap-4 p-4 overflow-hidden">
        <section className="flex flex-col gap-4">
          <div className="glass-panel rounded-xl p-5 flex flex-col flex-1">
            <h2 className="text-[10px] font-black uppercase mb-4 gemini-gradient">Controller</h2>
            <div className="space-y-5">
              <div className="flex items-center justify-between">
                <span className="text-xs font-mono text-slate-400">Evolution</span>
                <button onClick={() => setIsEvolutionActive(!isEvolutionActive)} className={`w-10 h-5 rounded-full relative transition-all ${isEvolutionActive ? 'bg-cyan-500' : 'bg-slate-800'}`}>
                  <div className={`absolute top-1 w-3 h-3 rounded-full bg-white transition-all ${isEvolutionActive ? 'left-6' : 'left-1'}`}></div>
                </button>
              </div>
              <div className="space-y-3">
                <div className="flex justify-between text-[10px] font-mono"><span>Sample Temp</span><span>{config.samplingTemp}</span></div>
                <input type="range" min="0.05" max="1" step="0.05" value={config.samplingTemp} onChange={e => setConfig({...config, samplingTemp:parseFloat(e.target.value)})} className="w-full h-1 bg-slate-800 appearance-none rounded" />
              </div>
              <div className="space-y-3">
                <div className="flex justify-between text-[10px] font-mono"><span>Diversity λ</span><span>{config.diversityLambda}</span></div>
                <input type="range" min="0" max="1" step="0.05" value={config.diversityLambda} onChange={e => setConfig({...config, diversityLambda:parseFloat(e.target.value)})} className="w-full h-1 bg-slate-800 appearance-none rounded" />
              </div>
              <div className="space-y-3">
                <div className="flex justify-between text-[10px] font-mono"><span>Graph Wt</span><span>{config.graphWeight}</span></div>
                <input type="range" min="0" max="1" step="0.05" value={config.graphWeight} onChange={e => setConfig({...config, graphWeight:parseFloat(e.target.value)})} className="w-full h-1 bg-slate-800 appearance-none rounded" />
              </div>
              <div className="space-y-3">
                <div className="flex justify-between text-[10px] font-mono"><span>Echo Wt</span><span>{config.echoWeight}</span></div>
                <input type="range" min="0" max="0.5" step="0.05" value={config.echoWeight} onChange={e => setConfig({...config, echoWeight:parseFloat(e.target.value)})} className="w-full h-1 bg-slate-800 appearance-none rounded" />
              </div>
              <div className="space-y-3">
                <div className="flex justify-between text-[10px] font-mono"><span>Max Mem</span><span>{config.maxMemory}</span></div>
                <input type="range" min="20" max="300" step="10" value={config.maxMemory} onChange={e => setConfig({...config, maxMemory:parseInt(e.target.value)})} className="w-full h-1 bg-slate-800 appearance-none rounded" />
              </div>
              <div className="space-y-3">
                <div className="flex justify-between text-[10px] font-mono"><span>Decay</span><span>{config.decayRate}</span></div>
                <input type="range" min="0.85" max="1" step="0.01" value={config.decayRate} onChange={e => setConfig({...config, decayRate:parseFloat(e.target.value)})} className="w-full h-1 bg-slate-800 appearance-none rounded" />
              </div>
              <div className="space-y-3">
                <div className="flex justify-between text-[10px] font-mono"><span>Gate</span><span>{config.noveltyThreshold.toFixed(3)}</span></div>
              </div>
              <div className="space-y-3">
                <div className="flex justify-between text-[10px] font-mono"><span>Fitness Min</span><span>{config.fitnessThreshold}</span></div>
                <input type="range" min="0" max="1" step="0.05" value={config.fitnessThreshold} onChange={e => setConfig({...config, fitnessThreshold:parseFloat(e.target.value)})} className="w-full h-1 bg-slate-800 appearance-none rounded" />
              </div>
              <div className="pt-4 border-t border-slate-800 space-y-4">
                <button onClick={() => wipeMemory()} className="w-full text-center text-red-500 text-[10px] uppercase font-bold hover:underline">Full System Purge</button>
              </div>
            </div>
          </div>
        </section>

        <section className="glass-panel rounded-xl p-4 flex flex-col lg:col-span-1 overflow-hidden">
          <h2 className="text-[10px] font-black uppercase text-slate-500 mb-3 tracking-widest">Neural Stream</h2>
          <div className="log-container flex-1 overflow-y-auto space-y-2 pr-2 font-mono text-[10px]">
            {logs.map((log,i) => (
              <div key={i} className={`p-1 ${log.includes('RESCUE')?'text-red-400':log.includes('SYSTEM')?'text-emerald-400':log.includes('EVOLVE')?'text-yellow-400':'text-slate-500'}`}>{log}</div>
            ))}
          </div>
        </section>

        <section className="lg:col-span-2 flex flex-col gap-4 overflow-hidden">
          <div className="glass-panel rounded-xl p-4 flex-1 flex flex-col overflow-hidden">
            <div className="chat-container flex-1 overflow-y-auto space-y-4 pr-2 mb-4">
              {chat.map((m,i) => (
                <div key={i} className={`p-4 rounded-xl text-xs font-mono border ${m.role==='user'?'bg-slate-800/50 border-slate-700 self-end ml-10':'bg-cyan-900/10 border-cyan-500/20 self-start mr-10'}`}>
                  <span className="opacity-30 block mb-1">[{m.role==='user'?'USER':'ACTUATOR'}]</span>
                  {m.text}
                </div>
              ))}
            </div>
            <div className="flex gap-2 p-2 bg-black/40 rounded-xl">
              <input type="text" value={prompt} onChange={e=>setPrompt(e.target.value)} onKeyDown={e=>e.key==='Enter'&&handleExecute()} placeholder="Interact with evolved brain..." className="flex-1 bg-transparent p-2 text-xs outline-none" />
              <button onClick={handleExecute} className="bg-cyan-600 hover:bg-cyan-500 text-white px-5 py-2 rounded-lg font-black text-[10px] uppercase">Execute</button>
            </div>
          </div>
          <div className="grid grid-cols-4 gap-4 text-center">
            <div className="glass-panel p-3 rounded-xl"><div className="text-[8px] text-slate-500 uppercase">Shards</div><div className="text-sm font-mono text-cyan-400">{telemetry.nodes}</div></div>
            <div className="glass-panel p-3 rounded-xl"><div className="text-[8px] text-slate-500 uppercase">Gen</div><div className="text-sm font-mono text-cyan-400">{telemetry.evolutionGen}</div></div>
            <div className="glass-panel p-3 rounded-xl"><div className="text-[8px] text-slate-500 uppercase">Entropy</div><div className="text-sm font-mono text-cyan-400">{telemetry.entropy}</div></div>
            <div className="glass-panel p-3 rounded-xl"><div className="text-[8px] text-slate-500 uppercase">Mode</div><div className={`text-sm font-mono ${telemetry.rescue?'text-red-400':'text-cyan-400'}`}>{telemetry.rescue?'RESCUE':'NORM'}</div></div>
          </div>
        </section>
      </main>

      {isModalOpen && (
        <div className="source-modal-overlay absolute inset-0 z-50 p-10 flex flex-col">
          <div className="glass-panel rounded-3xl overflow-hidden flex flex-col flex-1 border border-cyan-500/30">
            <div className="p-4 bg-slate-800 flex justify-between items-center">
              <span className="text-xs font-black uppercase tracking-widest text-cyan-400">Memory Repository</span>
              <button onClick={()=>setIsModalOpen(false)} className="bg-red-500/20 text-red-400 px-4 py-1 rounded font-bold text-xs">EXIT</button>
            </div>
            <pre className="flex-1 overflow-auto p-6 font-mono text-[10px] bg-black/80">{JSON.stringify(memoryBank.current, null, 2)}</pre>
          </div>
        </div>
      )}
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<App />);
</script>
</body>
</html>
