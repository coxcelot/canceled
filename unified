        nodeMapRef.current = m;
        const meta = await dbGetAll('meta');
        const eigenMeta = meta.find(m => m.key === 'eigen');
        if(eigenMeta && eigenMeta.vectors) await askWorker('EIGEN_LOAD', null, { vectors: eigenMeta.vectors });
        const cfg = meta.find(m => m.key === 'config');
        if(cfg && cfg.value) setConfig(prev => ({ ...prev, ...cfg.value }));
        const gen = meta.find(m => m.key === 'generation');
        if(gen) generationCount.current = gen.value || 0;
        setTelemetry(prev => ({ ...prev, nodes: nodes.length }));
