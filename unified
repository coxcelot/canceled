    noveltyThreshold: 0.85, decayRate: 0.98,
    graphWeight: 0.3, echoWeight: 0.15,
    fitnessThreshold: 0.25
  });

  const memoryBank = useRef([]);
  const nodeMapRef = useRef(new Map());
  const isGenerating = useRef(false);
